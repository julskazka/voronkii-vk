# Переменные окружения — ШАБЛОН
# Скопируй этот файл в .env и заполни реальными значениями.
# Файл .env НЕ коммитится в Git (добавлен в .gitignore).

# Пример: ключ внешнего API (если понадобится бекенд)
# API_KEY=your_api_key_here

# Пример: URL своего сервера
# API_URL=https://your-backend.com/api
